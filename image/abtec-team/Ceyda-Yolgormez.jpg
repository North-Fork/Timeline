			/* Container for the image and text */
.msg_head {
    position: relative;
    width: 293px;  /* Adjust as needed */
    max-width: 100%; /* Ensures responsiveness */
    height: auto; /* Allow dynamic height based on image */
    display: inline-block; /* Prevents extra spacing issues */
    overflow: hidden;
}

/* Ensure images are fully responsive */
.msg_head img {
    width: 100%;
    height: auto; /* Maintains aspect ratio */
    display: block; /* Prevents unwanted space below the image */
}

/* Text overlay */
.undergraduateresearchassistantstext {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.8); /* Slight transparency for better readability */
    color: #fff;
    text-align: center;
    font-size: 16px;
    padding: 10px 5px;
    box-sizing: border-box;
    font-weight: bold;
}

/* Ensure text does not overflow */
.undergraduateresearchassistantstext span {
    display: block;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis; /* Adds "..." if text is too long */
    max-width: 100%;
}

		</style>
		

